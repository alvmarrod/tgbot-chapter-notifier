# Bot identifier used as routing key for incoming events
BOT_ID=chaptnotifier

# Unique subscriber identity for tg-if gateway registration
SUBSCRIBER_ID=svc_chaptnotifier

# Telegram bot display name (not in use, fill freely)
BOT_NAME="ChapterNotifierBot"

# Telegram admin username for access control
ADMIN_USERNAME=AdminUser

# Path to the SQLite database file
DATABASE_FILEPATH=data/roger_db.db

# RabbitMQ broker — use the host/port exposed by your docker-compose or infra
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest